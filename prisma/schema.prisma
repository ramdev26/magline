generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderCategory {
  LV
  CMS
  MEP
}

enum UserRole {
  SUPER_ADMIN
  USER
}

enum CustomerStatus {
  NEW
  OLD
  ACTIVE
  INACTIVE
}

enum SalesDesignation {
  ASSISTANT_SALES_MANAGER
  SENIOR_SALES_EXECUTIVE
  SALES_EXECUTIVE
  JUNIOR_SALES_EXECUTIVE
}

enum SalesTeamStatus {
  ACTIVE
  SUSPENDED
}

enum SalesSuspensionReason {
  INACTIVE
  RESIGNED
  TERMINATED
  ON_LEAVE
  TRANSFERRED
  OTHER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(USER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id                  String            @id @default(cuid())
  name                String
  contact             String
  email               String
  phone               String
  address             String
  status              CustomerStatus    @default(NEW)
  salesPersonId       String?
  salesPerson         SalesPerson?      @relation(fields: [salesPersonId], references: [id], onDelete: SetNull)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  inquiries           Inquiry[]
  additionalContacts  CustomerContact[]
}

model CustomerContact {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contact    String   @default("")
  email      String   @default("")
  phone      String   @default("")
  createdAt  DateTime @default(now())
}

model HeadOfSales {
  id            String         @id @default(cuid())
  name          String
  department    String         @default("")
  createdAt     DateTime       @default(now())
  salesManagers SalesManager[]
}

model SalesManager {
  id                String                 @id @default(cuid())
  name              String
  department        String
  status            SalesTeamStatus        @default(ACTIVE)
  suspensionReason  SalesSuspensionReason?
  suspensionNote    String?
  suspendedAt       DateTime?
  headOfSalesId     String?
  headOfSales       HeadOfSales?           @relation(fields: [headOfSalesId], references: [id], onDelete: SetNull)
  createdAt         DateTime               @default(now())
  salesPersons      SalesPerson[]
}

model SalesPerson {
  id               String                 @id @default(cuid())
  name             String
  designation      SalesDesignation       @default(SALES_EXECUTIVE)
  status           SalesTeamStatus        @default(ACTIVE)
  suspensionReason SalesSuspensionReason?
  suspensionNote   String?
  suspendedAt      DateTime?
  managerId        String?
  manager          SalesManager?          @relation(fields: [managerId], references: [id], onDelete: SetNull)
  createdAt        DateTime               @default(now())
  inquiries        Inquiry[]
  customers        Customer[]
}

model Engineer {
  id        String    @id @default(cuid())
  name      String    @unique
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  inquiries Inquiry[]
}

model Inquiry {
  id                     String         @id @default(cuid())
  serialNo               Int            @unique @default(autoincrement())
  inquiryReceivedDate    DateTime?
  modeOfInquiry          String?
  customerId             String?
  customer               Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName           String         @default("")
  contactDetails         String?
  contactPhone           String?
  contactEmail           String?
  projectName            String?
  document               String?
  salesPersonId          String?
  salesPerson            SalesPerson?   @relation(fields: [salesPersonId], references: [id], onDelete: SetNull)
  quotationRequiredDate  DateTime?
  engineerId             String?
  engineer               Engineer?      @relation(fields: [engineerId], references: [id], onDelete: SetNull)
  quotationNo            String?
  quotationAmount        Decimal?       @db.Decimal(14, 2)
  quotationSubmittedDate DateTime?
  ongoingTender          String?
  jsbNo                  String?
  poNo                   String?
  poReceivedDate         DateTime?
  awardedParty           String?
  awardedPrice           Decimal?       @db.Decimal(14, 2)
  remarks                String?
  category               OrderCategory?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
}
