generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderCategory {
  LV
  CMS
  MEP
}

enum UserRole {
  SUPER_ADMIN
  USER
}

enum CustomerStatus {
  NEW
  OLD
  ACTIVE
  INACTIVE
}

enum CustomerActivityStatus {
  ACTIVE
  INACTIVE
}

enum SalesDesignation {
  ASSISTANT_SALES_MANAGER
  SENIOR_SALES_EXECUTIVE
  SALES_EXECUTIVE
  JUNIOR_SALES_EXECUTIVE
}

enum SalesTeamStatus {
  ACTIVE
  SUSPENDED
}

enum SalesSuspensionReason {
  INACTIVE
  RESIGNED
  TERMINATED
  ON_LEAVE
  TRANSFERRED
  OTHER
}

enum InquiryFollowUpStatus {
  CONSULTANT_REVIEW
  DRAWING_CONFIRMATION_SENT
  DRAWING_APPROVAL_PENDING
  PRICE_NEGOTIATING
  PENDING_CONSULTANT_APPROVAL
  CHANGES_PROPOSED_BY_MAGLINE
  CHANGES_PROPOSED_BY_CLIENT
  PENDING_TENDER
  TENDER_LOSS
  TENDER_WON
  OTHER_MATTER
}

enum WipPaymentStatus {
  NOT_PAID
  PAID_0_10
  PAID_10_50
  PAID_50_75
  PAID_75_99
  PAID_FULLY
  CREDIT_30_DAYS
  FULLY_ON_DELIVERY
}

enum WipDelayReason {
  COLOR_MISMATCHED
  COST_ISSUES
  ITEM_MISTAKES
  FACTORY_PRODUCTION
}

enum WipReturnReason {
  DAMAGED
  WRONG_CHANNEL
  PRODUCTION
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(USER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id                  String                 @id @default(cuid())
  name                String
  contact             String
  contactDesignation  String                 @default("")
  email               String
  phone               String
  address             String
  status              CustomerStatus         @default(NEW)
  activityStatus      CustomerActivityStatus @default(ACTIVE)
  salesPersonId       String?
  salesManagerId      String?
  headOfSalesId       String?
  salesPerson         SalesPerson?           @relation(fields: [salesPersonId], references: [id], onDelete: SetNull)
  salesManager        SalesManager?          @relation(fields: [salesManagerId], references: [id], onDelete: SetNull)
  headOfSales         HeadOfSales?           @relation(fields: [headOfSalesId], references: [id], onDelete: SetNull)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  inquiries           Inquiry[]
  additionalContacts  CustomerContact[]
  workInProgress      WorkInProgress[]
}

model CustomerContact {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contact     String   @default("")
  designation String   @default("")
  email       String   @default("")
  phone       String   @default("")
  createdAt   DateTime @default(now())
}

model HeadOfSales {
  id            String         @id @default(cuid())
  name          String
  department    String         @default("")
  createdAt     DateTime       @default(now())
  salesManagers SalesManager[]
  customers     Customer[]
  inquiries     Inquiry[]
}

model SalesManager {
  id                String                 @id @default(cuid())
  name              String
  department        String
  status            SalesTeamStatus        @default(ACTIVE)
  suspensionReason  SalesSuspensionReason?
  suspensionNote    String?
  suspendedAt       DateTime?
  headOfSalesId     String?
  headOfSales       HeadOfSales?           @relation(fields: [headOfSalesId], references: [id], onDelete: SetNull)
  createdAt         DateTime               @default(now())
  salesPersons      SalesPerson[]
  customers         Customer[]
  inquiries         Inquiry[]
}

model SalesPerson {
  id               String                 @id @default(cuid())
  name             String
  designation      SalesDesignation       @default(SALES_EXECUTIVE)
  status           SalesTeamStatus        @default(ACTIVE)
  suspensionReason SalesSuspensionReason?
  suspensionNote   String?
  suspendedAt      DateTime?
  managerId        String?
  manager          SalesManager?          @relation(fields: [managerId], references: [id], onDelete: SetNull)
  createdAt        DateTime               @default(now())
  inquiries        Inquiry[]
  customers        Customer[]
  workInProgress   WorkInProgress[]
}

model Engineer {
  id        String    @id @default(cuid())
  name      String    @unique
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  inquiries Inquiry[]
}

model Inquiry {
  id                     String         @id @default(cuid())
  serialNo               Int            @unique @default(autoincrement())
  inquiryReceivedDate    DateTime?
  modeOfInquiry          String?
  customerId             String?
  customer               Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName           String         @default("")
  contactDetails         String?
  contactPhone           String?
  contactEmail           String?
  projectName            String?
  document               String?
  salesPersonId          String?
  salesManagerId         String?
  headOfSalesId          String?
  salesPerson            SalesPerson?   @relation(fields: [salesPersonId], references: [id], onDelete: SetNull)
  salesManager           SalesManager?  @relation(fields: [salesManagerId], references: [id], onDelete: SetNull)
  headOfSales            HeadOfSales?   @relation(fields: [headOfSalesId], references: [id], onDelete: SetNull)
  quotationRequiredDate  DateTime?
  engineerId             String?
  engineer               Engineer?      @relation(fields: [engineerId], references: [id], onDelete: SetNull)
  quotationNo            String?
  quotationAmount        Decimal?       @db.Decimal(14, 2)
  quotationSubmittedDate DateTime?
  ongoingTender          String?
  jsbNo                  String?
  poNo                   String?
  poReceivedDate         DateTime?
  awardedParty           String?
  awardedPrice           Decimal?       @db.Decimal(14, 2)
  remarks                String?
  category               OrderCategory?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  documents              InquiryDocument[]
  followUps              InquiryFollowUp[]
}

model InquiryDocument {
  id        String   @id @default(cuid())
  inquiryId String
  inquiry   Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  fileName  String   @default("")
  remarks   String   @default("")
  fileData  String?  @db.Text
  createdAt DateTime @default(now())
}

model InquiryFollowUp {
  id           String                @id @default(cuid())
  inquiryId    String
  inquiry      Inquiry               @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  status       InquiryFollowUpStatus
  remarks      String                @default("")
  followUpDate DateTime?
  followUpBy   String                @default("")
  createdAt    DateTime              @default(now())
}

model WorkInProgress {
  id               String           @id @default(cuid())
  serialNo         Int              @unique @default(autoincrement())
  date             DateTime?
  jobNo            String?
  poNo             String?
  quotationNo      String?
  customerId       String?
  customer         Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName     String           @default("")
  salesPersonId    String?
  salesPerson      SalesPerson?     @relation(fields: [salesPersonId], references: [id], onDelete: SetNull)
  category         OrderCategory?
  orderDescription String           @default("")
  unit             String           @default("Nos")
  quantity         Decimal          @default(0) @db.Decimal(14, 2)
  rate             Decimal          @default(0) @db.Decimal(14, 2)
  discount         Decimal          @default(0) @db.Decimal(14, 2)
  vatPercent       Decimal          @default(18) @db.Decimal(5, 2)
  paymentStatus    WipPaymentStatus @default(NOT_PAID)
  productionStages String[]         @default([])
  deliveryStages   String[]         @default([])
  delayReason      WipDelayReason?
  delayNote        String?
  returnReason     WipReturnReason?
  returnNote       String?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}
